#include <stdio.h>

int main() {
    int arr[100], n, search, first, last, middle, found = 0;

    printf("Enter number of elements in array (sorted): ");
    scanf("%d", &n);

    printf("Enter %d elements in ascending order:\n", n);
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    printf("Enter number to search: ");
    scanf("%d", &search);

    first = 0;
    last = n - 1;

    while (first <= last) {
        middle = (first + last) / 2;

        if (arr[middle] == search) {
            printf("%d found at position %d\n", search, middle + 1);
            found = 1;
            break;
        } 
        else if (arr[middle] < search) {
            first = middle + 1;
        } 
        else {
            last = middle - 1;
        }
    }

    if (found == 0) {
        printf("%d is not present in the array\n", search);
    }

    return 0;
}
